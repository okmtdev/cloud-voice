{
  "name": "cloud-voice",
  "version": "0.1.0",
  "private": true,
  "description": "Send your voice to the cloud, hear it from any speaker. A realtime bridge between a web service and the speakers on your Mac / Linux machine.",
  "license": "MIT",
  "author": "Yuki Nakajima",
  "workspaces": [
    "server",
    "agent"
  ],
  "scripts": {
    "build": "tsc -p server/tsconfig.json && tsc -p agent/tsconfig.json",
    "dev:server": "npm run dev --workspace server",
    "dev:agent": "npm run dev --workspace agent",
    "start:server": "npm run start --workspace server",
    "start:agent": "npm run start --workspace agent",
    "lint": "npm run typecheck",
    "typecheck": "tsc -p server/tsconfig.json --noEmit && tsc -p agent/tsconfig.json --noEmit",
    "test": "node --experimental-strip-types --test \"server/test/*.test.ts\" \"agent/test/*.test.ts\""
  },
  "engines": {
    "node": ">=20"
  }
}
