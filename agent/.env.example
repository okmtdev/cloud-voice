# Cloud Voice agent configuration. Copy to `.env` and edit.

# The relay server. Use wss:// for the deployed Cloud Run URL.
CLOUD_VOICE_SERVER=wss://cloud-voice-xxxxxxxx.a.run.app

# Pairing code shared with the web UI. Pick anything memorable & unique.
CLOUD_VOICE_ROOM=kitchen-1234

# Optional shared secret. Must match the server's CLOUD_VOICE_TOKEN if set.
CLOUD_VOICE_TOKEN=

# Optional: force a default output device id at startup (see `--list-devices`).
# CLOUD_VOICE_DEVICE=
